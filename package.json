{
  "name": "cloudweave",
  "version": "1.0.0",
  "description": "CloudWeave - A unified cloud platform engineering application for managing multi-cloud infrastructure, deployments, and operations",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:performance": "artillery run tests/performance/load-test.yml",
    "test:api": "newman run tests/api/postman-collection.json -e tests/api/environment.json",
    "test:security": "jest --config tests/security/jest.config.js --runInBand",
    "test:security:vulnerability": "jest --config tests/security/jest.config.js --testPathPattern=vulnerability --runInBand",
    "test:security:compliance": "jest --config tests/security/jest.config.js --testPathPattern=compliance --runInBand",
    "test:security:penetration": "jest --config tests/security/jest.config.js --testPathPattern=penetration --runInBand",
    "test:security:audit": "jest --config tests/security/jest.config.js --testPathPattern=audit --runInBand",
    "test:security:report": "npm run test:security && node -e \"console.log('Security test reports generated in test-results/')\"",
    "test:security:all": "./scripts/run-security-tests.sh",
    "test:all": "npm run test && npm run test:e2e && npm run test:performance && npm run test:security",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "docker:build": "docker build -t cloudweave .",
    "docker:run": "docker run -p 3000:3000 cloudweave",
    "db:migrate": "knex migrate:latest",
    "db:rollback": "knex migrate:rollback",
    "db:seed": "knex seed:run",
    "db:reset": "knex migrate:rollback --all && knex migrate:latest && knex seed:run"
  },
  "keywords": [
    "cloud",
    "platform",
    "engineering",
    "infrastructure",
    "devops",
    "multi-cloud"
  ],
  "author": "Platform Engineering Team",
  "license": "MIT",
  "dependencies": {
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.0.1",
    "pg": "^8.11.3",
    "redis": "^4.6.10",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/axios": "^0.9.36",
    "@types/bcryptjs": "^2.4.5",
    "@types/compression": "^1.7.4",
    "@types/cors": "^2.8.15",
    "@types/express": "^4.17.20",
    "@types/jest": "^29.5.6",
    "@types/js-yaml": "^4.0.8",
    "@types/jsonwebtoken": "^9.0.4",
    "@types/node": "^20.8.7",
    "@types/pg": "^8.10.7",
    "@types/supertest": "^2.0.15",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/uuid": "^9.0.6",
    "@typescript-eslint/eslint-plugin": "^6.9.0",
    "@typescript-eslint/parser": "^6.9.0",
    "artillery": "^2.0.0",
    "eslint": "^8.52.0",
    "jest": "^29.7.0",
    "newman": "^6.0.0",
    "playwright": "^1.40.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
